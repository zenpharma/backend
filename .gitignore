.mvn/wrapper/maven-wrapper.jar

# Environment / secrets (never commit)
**/.env
**/.env.local
**/application-local.yml
**/application-secret.yml

# OS files
.DS_Store
Thumbs.db

# Test coverage
**/coverage/
**/jacoco.exec

# Logs
*.log
logs/
